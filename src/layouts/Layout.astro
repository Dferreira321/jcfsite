---
<!doctype html>
<html lang="pt"> <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>JCF Materiais de Construção</title>
    </head>
    <body>
        <Header /> <main>
            <slot />
        </main>
