---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contactos | JCF Materiais">
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-black text-jcf-black uppercase tracking-tight">Fale <span class="text-jcf-orange">Connosco</span></h1>
        <p class="text-gray-600 mt-4">Estamos em Santarém prontos para ajudar no seu projeto de construção.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        
        <div class="space-y-8">
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
            <h2 class="text-2xl font-bold mb-6 text-jcf-black">Dados de Contacto</h2>
            
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="bg-jcf-orange/10 p-3 rounded-lg text-jcf-orange">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <p class="font-bold text-jcf-black">Endereço</p>
                  <p class="text-gray-600">Rua Porto dos moleiros, São vicente do paul, Santarém, Portugal</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="bg-jcf-orange/10 p-3 rounded-lg text-jcf-orange">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <p class="font-bold text-jcf-black">Telefone Fixo</p>
                  <p class="text-gray-600">+351 243 428 365</p>
                </div>
                
              </div>

                 <div class="flex items-start gap-4">
                <div class="bg-jcf-orange/10 p-3 rounded-lg text-jcf-orange">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <p class="font-bold text-jcf-black">Contactos Balcão</p>
                  <p class="text-gray-600">+351 910 594 217</p>
                  <p class="text-gray-600">+351 929 438 351</p>

                </div>
              
              </div>

             


                 <div class="flex items-start gap-4">
                <div class="bg-jcf-orange/10 p-3 rounded-lg text-jcf-orange">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <p class="font-bold text-jcf-black">Escritório</p>
                  <p class="text-gray-600">+351 932 784 043</p>
                </div>
                
              </div>



              <div class="flex items-start gap-4">
                <div class="bg-jcf-orange/10 p-3 rounded-lg text-jcf-orange">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <p class="font-bold text-jcf-black">E-mail</p>
                  <p class="text-gray-600">geral@jcflda.pt</p>
                </div>
              </div>
            </div>
          </div>

          <a href="https://wa.me/351910594217" class="flex items-center justify-center gap-3 bg-green-600 text-white p-4 rounded-xl font-bold hover:bg-green-700 transition-colors shadow-lg shadow-green-600/20">
            <span class="text-xl">Falar pelo WhatsApp</span>
          </a>
        </div>

       <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
  <form action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
    
    <input type="hidden" name="access_key" value="a83a05bd-908d-4b96-9483-58216822b829">
    
    <input type="hidden" name="from_name" value="Site JCF - Novo Contacto">
    <input type="hidden" name="subject" value="Novo Contacto via Website JCF">

    <div>
      <label class="block text-sm font-bold text-jcf-black mb-1">Nome Completo</label>
      <input type="text" name="name" required class="w-full p-3 rounded-lg border border-gray-200 focus:border-jcf-orange focus:ring-2 focus:ring-jcf-orange/20 outline-none transition-all" placeholder="Seu nome...">
    </div>
    
    <div>
      <label class="block text-sm font-bold text-jcf-black mb-1">E-mail ou Telefone</label>
      <input type="text" name="contact" required class="w-full p-3 rounded-lg border border-gray-200 focus:border-jcf-orange focus:ring-2 focus:ring-jcf-orange/20 outline-none transition-all" placeholder="Como podemos contactá-lo?">
    </div>
    
    <div>
      <label class="block text-sm font-bold text-jcf-black mb-1">Assunto</label>
      <select name="subject_type" class="w-full p-3 rounded-lg border border-gray-200 outline-none focus:border-jcf-orange">
        <option>Pedido de Orçamento</option>
        <option>Informação Técnica</option>
        <option>Outros</option>
      </select>
    </div>
    
    <div>
      <label class="block text-sm font-bold text-jcf-black mb-1">Mensagem</label>
      <textarea name="message" rows="4" required class="w-full p-3 rounded-lg border border-gray-200 focus:border-jcf-orange focus:ring-2 focus:ring-jcf-orange/20 outline-none transition-all" placeholder="Liste os materiais ou a sua dúvida..."></textarea>
    </div>

    <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

    <button type="submit" class="w-full bg-jcf-black text-white font-bold py-4 rounded-xl hover:bg-jcf-orange transition-all uppercase tracking-widest">
      Enviar Mensagem
    </button>
  </form>
</div>
      </div>

<div class="mt-16 rounded-2xl overflow-hidden shadow-lg border border-gray-200">
  <iframe 
    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3087.653457002347!2d-8.6295556!3d39.2950556!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd188d1b57a3f2b1%3A0xe3e0336e099823d3!2sJo%C3%A3o%20Costa%20Ferreira%20-%20Materiais%20De%20Constru%C3%A7%C3%A3o!5e0!3m2!1spt-PT!2spt!4v1708375000000!5m2!1spt-PT!2spt" 
    width="100%" 
    height="450" 
    style="border:0;" 
    allowfullscreen="" 
    loading="lazy" 
    referrerpolicy="no-referrer-when-downgrade">
  </iframe>
</div>
    </div>
  </section>
</Layout>