---
import Layout from '../layouts/Layout.astro';

// Exemplo de dados para as categorias
const categorias = [
  {
    titulo: "Eletricidade",
    imagem: "https://images.unsplash.com/photo-1621905251189-08b45d6a269e?auto=format&fit=crop&w=600&q=80",
    destaques: ["Aparelhagem", "Cabos e Condutores", "Quadros Elétricos"],
    cor: "border-yellow-500"
  },
  {
    titulo: "Iluminação LED",
    imagem: "https://images.unsplash.com/photo-1565814329452-e1efa11c5b89?auto=format&fit=crop&w=600&q=80",
    destaques: ["Projetores Exterior", "Painéis LED", "Fitas LED"],
    cor: "border-blue-400"
  },
  {
    titulo: "Pladur e Divisórias",
    imagem: "https://images.unsplash.com/photo-1504148455328-c376907d081c?auto=format&fit=crop&w=600&q=80",
    destaques: ["Placas Hidrófugas", "Perfilaria", "Massas de Juntas"],
    cor: "border-gray-400"
  },
  {
    titulo: "Isolamentos",
    imagem: "https://images.unsplash.com/photo-1584622650111-993a426fbf0a?auto=format&fit=crop&w=600&q=80",
    destaques: ["Lã de Rocha", "Poliestireno (EPS/XPS)", "Telas Térmicas"],
    cor: "border-orange-500"
  }
];
---

<Layout title="Produtos | JCF Materiais">
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      
      <div class="mb-12">
        <h1 class="text-4xl font-black text-jcf-black uppercase italic">
          O Nosso <span class="text-jcf-orange">Catálogo</span>
        </h1>
        <p class="text-gray-600 max-w-2xl mt-2">
          Dispomos de mais de 4.000 referências em stock. Explore as nossas principais gamas de produtos para a sua obra.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {categorias.map((cat) => (
          <div class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all border-b-4 {cat.cor} group">
            <div class="h-48 overflow-hidden">
              <img src={cat.imagem} alt={cat.titulo} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            
            <div class="p-6">
              <h3 class="text-xl font-bold text-jcf-black mb-4">{cat.titulo}</h3>
              
              <ul class="mb-6 space-y-2">
                {cat.destaques.map((item) => (
                  <li class="text-sm text-gray-500 flex items-center gap-2">
                    <span class="w-1.5 h-1.5 bg-jcf-orange rounded-full"></span>
                    {item}
                  </li>
                ))}
              </ul>

              <button class="w-full py-2 bg-gray-100 text-jcf-black font-bold rounded-lg hover:bg-jcf-black hover:text-white transition-colors">
                Ver Gama Completa
              </button>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-16 bg-jcf-black rounded-3xl p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-8">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Não encontra o que procura?</h2>
          <p class="text-gray-400">Com 4.000 artigos, o que precisa está certamente no nosso armazém.</p>
        </div>
        <a href="/contactos" class="px-8 py-4 bg-jcf-orange text-white font-black uppercase rounded-xl hover:scale-105 transition-transform text-center">
          Consultar Stock Especializado
        </a>
      </div>

    </div>
  </section>
</Layout>