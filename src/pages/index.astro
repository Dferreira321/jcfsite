---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Marcas from '../components/Marcas.astro';
import Total from '../components/TotalTools.astro'
---

<Layout title="Início | JCF Materiais">
    <Hero/>
    
    <Marcas/>

    <Total/> <section class="py-16 text-center"></section>

    <section class="py-16 text-center bg-gray-50">
        <div class="container mx-auto px-4">
            <h2 class="text-3xl md:text-4xl font-black text-jcf-black uppercase italic">
                Especialistas em <span class="text-jcf-orange">Materiais de Construção</span>
            </h2>
            <p class="text-gray-600 mt-4 text-lg max-w-2xl mx-auto">
                Mais de 20 anos a servir a região de Santarém com as melhores soluções e preços competitivos.
            </p>
        </div>
    </section>

<section class="py-16 bg-zinc-900 overflow-hidden relative group">
  <div class="absolute inset-0 opacity-10 pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="bg-white/5 border border-white/10 p-8 md:p-12 rounded-3xl backdrop-blur-sm shadow-2xl">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-10">
        
        <div class="lg:w-2/3">
          <div class="inline-block px-4 py-1 bg-white text-zinc-900 text-xs font-black uppercase tracking-tighter mb-4 rounded-full">
            Grupo JCF | Especialistas em Aço
          </div>
          <h2 class="text-3xl md:text-5xl font-black text-white uppercase italic leading-tight">
            Precisa de Estruturas ou <span class="text-jcf-orange italic">Coberturas?</span>
          </h2>
          <p class="text-zinc-400 text-lg mt-6 leading-relaxed max-w-2xl">
            Através da nossa empresa parceira, fornecemos a solução completa para pavilhões e coberturas: 
            <strong class="text-white font-bold">Painel Sandwich</strong> (Térmico e Acústico), <strong class="text-white font-bold">Omegas Galvanizadas</strong> e <strong class="text-white font-bold">Tubos Estruturais</strong>.
          </p>
        </div>

        <div class="lg:w-1/3 flex flex-col gap-4 w-full">
          <a href="https://site-da-outra-empresa.pt" target="_blank" class="w-full py-5 bg-white text-zinc-900 text-center font-black uppercase tracking-widest rounded-xl hover:bg-jcf-orange hover:text-white transition-all duration-300 shadow-xl">
            Visitar Site da Empresa
          </a>
          <p class="text-zinc-500 text-xs text-center">
            Consulte stock de material galvanizado e painel.
          </p>
        </div>

      </div>
    </div>
  </div>
</section>


   
</Layout>