      </div>

      <div>
        <h4 class="text-lg font-bold mb-6 text-white uppercase tracking-wider">Categorias</h4>
        <ul class="space-y-4 text-gray-400">
          <li><a href="/produtos" class="hover:text-jcf-orange transition-colors">Pladur e Isolamentos</a></li>
          <li><a href="/produtos" class="hover:text-jcf-orange transition-colors">Eletricidade e LED</a></li>
          <li><a href="/produtos" class="hover:text-jcf-orange transition-colors">Canalização e Saneamento</a></li>
          <li><a href="/produtos" class="hover:text-jcf-orange transition-colors">Ferramentas Total Tools</a></li>
