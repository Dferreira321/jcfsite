          </a>
        </div>
      </div>

      <div>
        <h4 class="text-lg font-bold mb-6 text-white uppercase tracking-wider">Links Rápidos</h4>
        <ul class="space-y-4 text-gray-400">
          <li><a href="/" class="hover:text-jcf-orange transition-colors">Início</a></li>
          <li><a href="/produtos" class="hover:text-jcf-orange transition-colors">Catálogo de Produtos</a></li>
          <li><a href="/contactos" class="hover:text-jcf-orange transition-colors">Pedir Orçamento</a></li>
          <li><a href="/sobre" class="hover:text-jcf-orange transition-colors">Sobre Nós</a></li>
