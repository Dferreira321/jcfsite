---
import { Image } from 'astro:assets';
import logoJcf from '../assets/logo-jcf.png';
---

<header class="bg-white border-b-4 border-jcf-orange shadow-md sticky top-0 z-50">
  <div class="container mx-auto px-4 py-2 flex justify-between items-center">
    
    <a href="/" class="flex items-center gap-3">
      <Image src={logoJcf} alt="JCF Logo" class="h-14 w-auto" />
    </a>

    <nav id="navMenu" class="hidden md:flex gap-6 text-xs font-bold uppercase absolute md:relative top-full left-0 w-full md:w-auto bg-white md:bg-transparent flex-col md:flex-row items-center p-6 md:p-0 border-b-2 border-jcf-orange md:border-none shadow-lg md:shadow-none">
      <a href="/" class="hover:text-jcf-orange">Início</a>
      <a href="/produtos" class="hover:text-jcf-orange">Produtos</a>
      <a href="/marcas" class="hover:text-jcf-orange">Marcas</a>
      <a href="/contactos" class="hover:text-jcf-orange">Contactos</a>
    </nav>

    <div class="flex items-center gap-4">
      <a href="/contactos" class="bg-jcf-red text-white px-4 py-2 rounded font-bold text-xs hover:bg-jcf-orange transition-colors">
        ORÇAMENTO
      </a>

      <button id="menuBtn" class="md:hidden text-jcf-black focus:outline-none" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path id="menuPath" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

  </div>
</header>

<script>
  const menuBtn = document.getElementById('menuBtn');
  const navMenu = document.getElementById('navMenu');
  const menuPath = document.getElementById('menuPath');

  menuBtn?.addEventListener('click', () => {
    // Alterna entre mostrar (flex) e esconder (hidden)
    navMenu?.classList.toggle('hidden');
    navMenu?.classList.toggle('flex');

    // Muda o ícone entre Hambúrguer e X
    const isOpen = navMenu?.classList.contains('flex');
    if (menuPath) {
      menuPath.setAttribute('d', isOpen 
        ? 'M6 18L18 6M6 6l12 12' 
        : 'M4 6h16M4 12h16M4 18h16'
      );
    }
  });

  // Fecha o menu ao clicar num link (importante para navegação na mesma página)
  const links = navMenu?.querySelectorAll('a');
  links?.forEach(link => {
    link.addEventListener('click', () => {
      navMenu?.classList.add('hidden');
      navMenu?.classList.remove('flex');
      menuPath?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    });
  });
</script>