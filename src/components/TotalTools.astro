---
const categoriasTotal = [
  {
    titulo: "Ferramentas Manuais",
    imagem: "https://images.unsplash.com/photo-1581147036324-c17ac41dfa6c?auto=format&fit=crop&w=600&q=80",
    desc: "Qualidade profissional para uso intensivo."
  },
  {
    titulo: "Máquinas a Bateria",
    imagem: "https://images.unsplash.com/photo-1504148455328-c376907d081c?auto=format&fit=crop&w=600&q=80", // Podes trocar por uma foto de aparafusadora
    desc: "Liberdade total com o sistema P20S."
  },
  {
    titulo: "Máquinas Elétricas",
    imagem: "https://images.unsplash.com/photo-1530124410731-299f187a070c?auto=format&fit=crop&w=600&q=80",
    desc: "Potência extrema para os trabalhos mais duros."
  }
];
---

<section class="py-20 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row items-end justify-between mb-12 gap-6">
      <div class="max-w-xl">
        <h2 class="text-4xl font-black text-jcf-black uppercase italic italic leading-none">
          Revendedor <span class="text-cyan-600">Ferramentas Total</span>
        </h2>
        <p class="text-gray-600 mt-4">
          A gama completa de ferramentas que combina performance profissional com o melhor preço do mercado.
        </p>
         
      </div>
      
      <div class="flex flex-wrap gap-4">
        <a href="/catalogos/total-geral.pdf" download class="flex items-center gap-3 px-6 py-3 bg-jcf-black text-white rounded-lg font-bold hover:bg-gray-800 transition-all text-sm uppercase tracking-tighter">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Catálogo Geral
        </a>
        <a href="/catalogos/total-promo.pdf" download class="flex items-center gap-3 px-6 py-3 bg-cyan-600 text-white rounded-lg font-bold hover:bg-cyan-700 transition-all text-sm uppercase tracking-tighter">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12z" />
          </svg>
          Campanha Promocional
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {categoriasTotal.map((item) => (
        <div class="group relative h-96 overflow-hidden rounded-2xl shadow-lg">
          <img 
            src={item.imagem} 
            alt={item.titulo} 
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 grayscale-[20%] group-hover:grayscale-0"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-jcf-black/90 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-8">
            <h3 class="text-2xl font-black text-white uppercase italic">{item.titulo}</h3>
            <p class="text-cyan-400 font-medium mt-1">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>